POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

DATABASE_PORT=5432
BACKEND_PORT=8080
CLIENT_PORT=3000

JWT_SECRET=secret

PROVIDERS_CONFIG_PATH=./backend/providers.yml

# Provider API keys (referenced by api_key_env in providers.yml)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Security: set to "false" in production to disable /dummyLogin endpoint
ENABLE_DUMMY_LOGIN=true

# MCP proxy: upstream LLM API URL (used by the project guide assistant)
UPSTREAM_URL=https://api.deepseek.com/v1
